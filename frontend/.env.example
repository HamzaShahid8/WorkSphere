# --- API target (no URLs hardcoded in source) ---
# Mode A — Browser calls Django directly (set CORS on backend for your Vite origin).
# VITE_API_BASE_URL=http://127.0.0.1:8000
#
# Mode B — Empty base URL + Vite proxies /api and /accounts (recommended for `npm run dev`).
VITE_API_BASE_URL=

# Where the dev server forwards /api and /accounts (override if Django runs elsewhere).
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Optional (local dev only): JWT access token from POST /accounts/login/ — not used in production builds.
# VITE_DEV_BEARER_TOKEN=