# Copy to `.env` in this folder (same directory as manage.py).
# Loaded automatically via python-dotenv in settings.

# Comma-separated browser origins for CORS (override defaults in settings).
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Comma-separated Django ALLOWED_HOSTS
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
